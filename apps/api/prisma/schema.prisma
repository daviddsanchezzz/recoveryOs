generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String          @id @default(cuid())
  email           String          @unique
  emailVerified   Boolean         @default(false)
  image           String?
  passwordHash    String?
  name            String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  accounts        Account[]
  sessions        Session[]
  weightEntries   WeightEntry[]
  injuries        Injury[]
  injuryLogs      InjuryLog[]
  sleepEntries    SleepEntry[]
  nutritionLogs   NutritionLog[]
  activities      Activity[]
  weeklySummaries WeeklySummary[]
  goals           Goal[]
  programs        Program[]
  weekPlanDays    WeekPlanDay[]
  weekTemplateDays WeekTemplateDay[]
  stravaToken     StravaToken?
}

model Session {
  id        String   @id
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

model WeightEntry {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime
  weightKg  Float
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Injury {
  id          String      @id @default(cuid())
  userId      String
  name        String
  bodyPart    String?
  description String?
  startDate   DateTime
  status      String      @default("active") // active | recovering | resolved
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs        InjuryLog[]

  @@index([userId])
}

model InjuryLog {
  id        String   @id @default(cuid())
  injuryId  String
  userId    String
  date      DateTime
  painLevel Int      // 0-10
  didRehab  Boolean  @default(false)
  notes     String?
  createdAt DateTime @default(now())
  injury    Injury   @relation(fields: [injuryId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([injuryId])
}

model SleepEntry {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime
  durationH Float
  quality   Int      // 1-5
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

model NutritionLog {
  id           String   @id @default(cuid())
  userId       String
  consumedAt   DateTime
  rawText      String
  calories     Int
  proteinGrams Float
  carbsGrams   Float
  fatGrams     Float
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Activity {
  id             String   @id @default(cuid())
  userId         String
  type           String           // gym | bike | run | walk | swim | mobility | rehab | other
  source         String           // manual | strava | coros
  performedAt    DateTime
  createdAt      DateTime @default(now())

  // Common
  durationMin    Int?
  calories       Int?             // kcal
  avgHeartRate   Int?             // bpm
  maxHeartRate   Int?             // bpm
  notes          String?

  // Distance activities (run, walk, bike)
  distanceKm     Float?
  elevationGainM Float?           // meters

  // Run / Walk
  avgPaceSecPerKm Float?          // seconds/km → display as mm:ss/km
  avgCadenceSpm  Int?             // steps/min

  // Bike
  avgSpeedKmh    Float?           // km/h
  avgPowerW      Int?             // watts
  avgCadenceRpm  Int?             // rpm
  kilojoules     Float?           // kJ (from Strava)

  // Swim
  distanceM      Int?             // meters
  avgPace100mSec Int?             // seconds per 100m

  // Gym
  muscleGroups   String[]         // pecho | espalda | biceps | triceps | hombro | core | pierna | gluteo
  totalVolumeKg  Float?           // total kg lifted

  // Strava integration (stravaId as String to avoid BigInt JSON issues)
  stravaId       String?  @unique // Strava activity ID — used for deduplication
  stravaName     String?          // activity name from Strava

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, performedAt])
}

model WeeklySummary {
  id              String   @id @default(cuid())
  userId          String
  weekStart       DateTime
  weekEnd         DateTime
  summaryMarkdown String
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OAuthState {
  state     String   @id
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

model StravaToken {
  id              String    @id @default(cuid())
  userId          String    @unique
  accessToken     String
  refreshToken    String
  expiresAt       DateTime
  stravaAthleteId String
  lastSyncAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WeekPlanDay {
  id        String   @id @default(cuid())
  userId    String
  date      String   // YYYY-MM-DD
  entries   Json     // PlanEntry[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}

model WeekTemplateDay {
  id        String   @id @default(cuid())
  userId    String
  dayIndex  Int      // 0=Mon … 6=Sun
  entries   Json     // PlanEntry[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dayIndex])
  @@index([userId])
}

model Goal {
  id          String   @id @default(cuid())
  userId      String
  label       String
  progressPct Int      @default(0)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Program {
  id          String   @id @default(cuid())
  userId      String
  name        String
  totalWeeks  Int
  currentWeek Int      @default(1)
  isActive    Boolean  @default(true)
  startDate   DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
